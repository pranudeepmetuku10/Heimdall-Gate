# Copy this file to .env and fill in. Lines that start with `#` are comments.

# --- Yelp Fusion ---
# Get a key at https://docs.developer.yelp.com/docs/fusion-intro
YELP_API_KEY=

# --- Ingestion targeting ---
# Comma-separated. Yelp accepts free-form location strings.
HEIMDALL_CITIES=Boston,Seattle,Austin
HEIMDALL_TERMS=restaurants
HEIMDALL_PAGE_SIZE=50
HEIMDALL_MAX_PAGES_PER_CITY=4

# Seconds between full sweeps when the runner is in loop mode.
HEIMDALL_POLL_INTERVAL_SEC=900

# Hard ceiling on API calls per process lifetime. Defense against runaway loops
# eating the 5,000/day Yelp quota.
HEIMDALL_API_CALL_BUDGET=2000

# --- Kafka ---
# For local dev: localhost:9094 (the external listener in docker-compose.yml).
# For Confluent Cloud: pkc-xxxxx.<region>.<cloud>.confluent.cloud:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

KAFKA_TOPIC_RAW=heimdall.raw.business
KAFKA_TOPIC_DLQ=heimdall.dlq.ingest

# PLAINTEXT for local, SASL_SSL for managed Kafka.
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# Only used when KAFKA_SECURITY_PROTOCOL=SASL_SSL.
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Producer tuning. Defaults are fine for the local demo.
KAFKA_LINGER_MS=20
KAFKA_BATCH_SIZE=65536
KAFKA_COMPRESSION_TYPE=lz4
KAFKA_ENABLE_IDEMPOTENCE=true
KAFKA_ACKS=all
KAFKA_MAX_IN_FLIGHT=5

# --- Optional file sink (volume-source mode for Databricks Free Edition) ---
HEIMDALL_FILE_SINK_ENABLED=false
HEIMDALL_FILE_SINK_PATH=./out/raw_drop

# --- Logging ---
# Levels: DEBUG INFO WARNING ERROR
HEIMDALL_LOG_LEVEL=INFO
# Formatters: json | console
HEIMDALL_LOG_FORMAT=console

# Process identifier baked into every emitted envelope. Useful when running
# multiple ingestion processes against the same topic.
HEIMDALL_PRODUCER_ID=heimdall-ingest-local
